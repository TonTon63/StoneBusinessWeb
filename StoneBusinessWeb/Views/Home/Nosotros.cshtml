@{
    ViewData["Title"] = "Nosotros";
}

<section class="page-banner small-banner">
    <div class="container">
        <span class="eyebrow">Nosotros</span>
        <h1>Experiencia, detalle y compromiso en cada proyecto</h1>
    </div>
</section>

<section class="section">
    <div class="container intro-grid">
        <div>
            <img src="~/images/about.jpg" alt="Equipo de trabajo" class="rounded-img" />
        </div>
        <div>
            <h2>Una empresa enfocada en calidad y confianza</h2>
            <p>
                Somos una empresa dedicada al diseño, fabricación e instalación de superficies
                en granito, cuarzo, mármol y porcelánico.
            </p>
            <p>
                Nuestro objetivo es ofrecer soluciones elegantes, funcionales y duraderas,
                adaptadas a las necesidades de cada cliente y de cada espacio.
            </p>
            <p>
                Trabajamos con atención al detalle, materiales de calidad y una ejecución
                profesional desde la cotización hasta la instalación final.
            </p>
        </div>
    </div>
</section>

<section class="section section-alt">
    <div class="container">
        <div class="section-heading center">
            <span class="eyebrow">Nuestra esencia</span>
            <h2>Lo que nos caracteriza</h2>
        </div>

        <div class="cards-grid three">
            <article class="service-box">
                <h3>Calidad</h3>
                <p>Seleccionamos materiales y acabados que aportan valor y durabilidad.</p>
            </article>
            <article class="service-box">
                <h3>Responsabilidad</h3>
                <p>Nos enfocamos en cumplir tiempos y trabajar con orden y compromiso.</p>
            </article>
            <article class="service-box">
                <h3>Atención personalizada</h3>
                <p>Cada proyecto recibe acompañamiento cercano desde el inicio hasta la entrega.</p>
            </article>
        </div>
    </div>
</section>