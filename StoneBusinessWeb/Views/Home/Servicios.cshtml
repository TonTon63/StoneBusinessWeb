@{
    ViewData["Title"] = "Servicios";
}

<section class="page-banner small-banner">
    <div class="container">
        <span class="eyebrow">Servicios</span>
        <h1>Trabajos pensados para resaltar cada espacio</h1>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="cards-grid three">
            <article class="service-box tall">
                <h3>Sobres de cocina</h3>
                <p>Fabricación e instalación de sobres en granito, cuarzo, mármol y porcelánico.</p>
            </article>

            <article class="service-box tall">
                <h3>Islas de cocina</h3>
                <p>Diseños modernos y funcionales para cocinas residenciales o comerciales.</p>
            </article>

            <article class="service-box tall">
                <h3>Baños y lavamanos</h3>
                <p>Soluciones elegantes para baños con materiales resistentes y de alto impacto visual.</p>
            </article>

            <article class="service-box tall">
                <h3>Revestimientos</h3>
                <p>Aplicaciones decorativas en paredes, fachadas y áreas interiores.</p>
            </article>

            <article class="service-box tall">
                <h3>Escaleras</h3>
                <p>Acabados sobrios y sofisticados para escaleras residenciales o comerciales.</p>
            </article>

            <article class="service-box tall">
                <h3>Proyectos personalizados</h3>
                <p>Diseños especiales según la necesidad del cliente y del espacio disponible.</p>
            </article>
        </div>
    </div>
</section>